---
const links = [
  { href: '#about',      label: 'About' },
  { href: '#skills',     label: 'Skills' },
  { href: '#experience', label: 'Experience' },
  { href: '#projects',   label: 'Projects' },
  { href: '#contact',    label: 'Contact' },
];
---

<nav
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-5 md:px-12 py-5
         transition-all duration-300"
  style="font-family:'DM Sans',sans-serif;"
>
  <a
    href="#hero"
    class="font-display font-extrabold text-lg tracking-tight text-[var(--text-primary)]
           no-underline transition-opacity hover:opacity-80"
    style="font-family:'Syne',sans-serif;"
  >
    Deepanshu <span style="color:var(--cyan)">Bajaj</span>
  </a>

  <!-- Desktop links -->
  <ul class="hidden md:flex gap-10 list-none">
    {links.map(({ href, label }) => (
      <li>
        <a
          href={href}
          class="relative text-[0.8rem] font-normal tracking-widest uppercase
                 text-[var(--text-muted)] no-underline
                 transition-colors duration-200 hover:text-[var(--text-primary)]
                 after:absolute after:bottom-[-3px] after:left-0 after:w-0 after:h-px
                 after:bg-[var(--cyan)] after:transition-all after:duration-300
                 hover:after:w-full"
        >
          {label}
        </a>
      </li>
    ))}
  </ul>

  <!-- Desktop CTA -->
  <a
    href="#contact"
    class="hidden md:inline-flex text-[0.78rem] font-medium px-5 py-2 rounded-md
           tracking-widest uppercase border transition-all duration-200
           text-[var(--cyan)] no-underline"
    style="border-color:rgba(15,244,198,0.3);background:rgba(15,244,198,0.06);"
    onmouseover="this.style.background='rgba(15,244,198,0.14)'"
    onmouseout="this.style.background='rgba(15,244,198,0.06)'"
  >
    Let's Talk
  </a>

  <!-- Hamburger -->
  <button
    id="nav-toggle"
    class="md:hidden flex flex-col gap-[5px] p-2 rounded-md transition-colors"
    style="background:none;border:none;cursor:pointer;"
    aria-label="Toggle menu"
  >
    <span class="ham-line block w-5 h-px transition-all duration-300" style="background:var(--text-primary);"></span>
    <span class="ham-line block w-5 h-px transition-all duration-300" style="background:var(--text-primary);"></span>
    <span class="ham-line block w-3 h-px transition-all duration-300" style="background:var(--text-primary);"></span>
  </button>
</nav>

<!-- Mobile menu -->
<div
  id="mobile-menu"
  class="fixed left-0 right-0 z-40 md:hidden overflow-hidden transition-all duration-300"
  style="top:65px;max-height:0;background:rgba(8,11,15,0.97);backdrop-filter:blur(20px);
         -webkit-backdrop-filter:blur(20px);border-bottom:1px solid transparent;"
>
  <ul class="flex flex-col list-none px-5 py-5 gap-1">
    {links.map(({ href, label }) => (
      <li>
        <a
          href={href}
          class="mobile-nav-link block py-3 text-[0.85rem] tracking-widest uppercase
                 no-underline transition-colors duration-200"
          style="color:var(--text-muted);border-bottom:1px solid var(--border);"
        >
          {label}
        </a>
      </li>
    ))}
    <li class="pt-3">
      <a
        href="#contact"
        class="block text-center text-[0.78rem] font-medium px-5 py-3 rounded-md
               tracking-widest uppercase border transition-all duration-200
               text-[var(--cyan)] no-underline"
        style="border-color:rgba(15,244,198,0.3);background:rgba(15,244,198,0.06);"
      >
        Let's Talk
      </a>
    </li>
  </ul>
</div>

<style>
  #main-nav.scrolled {
    background: rgba(8, 11, 15, 0.88);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
  }
  .mobile-nav-link:hover { color: var(--text-primary) !important; }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');
  const lines = document.querySelectorAll<HTMLElement>('.ham-line');
  let open = false;

  toggle?.addEventListener('click', () => {
    open = !open;
    if (menu) {
      menu.style.maxHeight = open ? '400px' : '0';
      menu.style.borderBottomColor = open ? 'var(--border)' : 'transparent';
    }
    if (lines[0]) lines[0].style.transform = open ? 'translateY(6px) rotate(45deg)' : '';
    if (lines[1]) lines[1].style.transform = open ? 'translateY(-6px) rotate(-45deg)' : '';
    if (lines[2]) lines[2].style.opacity = open ? '0' : '1';
  });

  // Close on link click
  document.querySelectorAll('#mobile-menu a').forEach((a) => {
    a.addEventListener('click', () => {
      open = false;
      if (menu) { menu.style.maxHeight = '0'; menu.style.borderBottomColor = 'transparent'; }
      if (lines[0]) lines[0].style.transform = '';
      if (lines[1]) lines[1].style.transform = '';
      if (lines[2]) lines[2].style.opacity = '1';
    });
  });
</script>
